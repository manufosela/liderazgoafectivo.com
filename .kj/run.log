7→  }\n   348→\n   349→  .key-section__card h2 {\n   350→    font-size: 1.5rem;\n   351→    margin-bottom: var(--space-sm);\n   352→  }\n   353→\n   354→  .key-section__card p {\n   355→    color: var(--color-text-light);\n   356→    margin-bottom: var(--space-md);\n   357→    font-size: 1.05rem;\n   358→  }\n   359→\n   360→  /* ===== Footer ===== */\n   361→  .footer {\n   362→    padding: var(--space-lg) 0;\n   363→    text-align: center;\n   364→    color: var(--color-text-light);\n   365→    font-size: 0.9rem;\n   366→    border-top: 1px solid var(--color-bg-accent);\n   367→  }\n   368→</style>\n   369→"}]},"parent_tool_use_id":null,"session_id":"36720bb4-df6a-45e4-99c2-812d270b6d7e","uuid":"a0881a8f-c4ff-4397-b227-f1cba7800383","tool_use_result":{"type":"text","file":{"filePath":"/home/manu/ws_astro/comunidad.liderazgoafectivo.com/src/pages/index.astro","content":"---\nimport Layout from '../layouts/Layout.astro';\n\nconst title = 'Comunidad de Liderazgo Afectivo — Aprende a liderar personas';\nconst description =\n  'Únete a la Comunidad de Liderazgo Afectivo: charlas mensuales en directo, contenido exclusivo y contacto directo con Mánu Fosela.';\n---\n\n<Layout title={title} description={description}>\n  <!-- Hero -->\n  <section class=\"hero\">\n    <div class=\"container\">\n      <h1 class=\"hero__title\">\n        ¿Y si liderar bien fuera la decisión más estratégica de tu vida?\n      </h1>\n      <p class=\"hero__subtitle\">\n        Únete a la Comunidad de Liderazgo Afectivo: un espacio donde aprender a\n        liderar personas, no gestionar recursos.\n      </p>\n      <a href=\"/registro\" class=\"btn btn--primary\">\n        Quiero apuntarme a la próxima charla\n      </a>\n    </div>\n  </section>\n\n  <!-- Hook -->\n  <section class=\"hook\">\n    <div class=\"container\">\n      <p class=\"hook__text\">\n        Durante años nos han enseñado que liderar es sinónimo de controlar,\n        presionar y medir resultados. Pero los equipos que más rinden, más\n        innovan y menos se van son los que tienen detrás a alguien que sabe\n        escuchar, conectar y acompañar.\n      </p>\n      <p class=\"hook__highlight\">\n        Eso es el Liderazgo Afectivo. Y ahora tiene comunidad.\n      </p>\n    </div>\n  </section>\n\n  <!-- What is -->\n  <section class=\"what-is\">\n    <div class=\"container\">\n      <h2>¿Qué es la Comunidad?</h2>\n      <p>\n        Un espacio mensual de aprendizaje, reflexión y conversación en torno al\n        liderazgo que transforma. Cada mes nos reunimos en directo para hablar\n        de liderazgo real: el que ocurre en el día a día de los equipos.\n      </p>\n    </div>\n  </section>\n\n  <!-- Benefits -->\n  <section class=\"benefits\">\n    <div class=\"container\">\n      <h2>¿Qué vas a obtener?</h2>\n      <ul class=\"benefits__list\">\n        <li class=\"benefits__item\">\n          <span class=\"benefits__icon\" aria-hidden=\"true\">🎙️</span>\n          <span>Una charla mensual online en directo con Mánu Fosela (vía Zoom/Meet)</span>\n        </li>\n        <li class=\"benefits__item\">\n          <span class=\"benefits__icon\" aria-hidden=\"true\">💬</span>\n          <span>Acceso al canal privado de WhatsApp/Telegram de la comunidad</span>\n        </li>\n        <li class=\"benefits__item\">\n          <span class=\"benefits__icon\" aria-hidden=\"true\">🤝</span>\n          <span>Contacto directo con Mánu para dudas, reflexiones y casos reales</span>\n        </li>\n        <li class=\"benefits__item\">\n          <span class=\"benefits__icon\" aria-hidden=\"true\">🔒</span>\n          <span>Contenido exclusivo que no se publica en ningún otro sitio</span>\n        </li>\n        <li class=\"benefits__item\">\n          <span class=\"benefits__icon\" aria-hidden=\"true\">❤️</span>\n          <span>Una comunidad de personas que lideran (o quieren liderar) desde el afecto</span>\n        </li>\n      </ul>\n    </div>\n  </section>\n\n  <!-- For who -->\n  <section class=\"for-who\">\n    <div class=\"container\">\n      <h2>¿Para quién es?</h2>\n      <ul class=\"for-who__list\">\n        <li>Líderes de equipos que quieren mejorar la forma en que acompañan a su gente</li>\n        <li>Profesionales con responsabilidad sobre personas que se sienten solos en ese rol</li>\n        <li>Personas que han leído Liderazgo Afectivo y quieren seguir profundizando</li>\n        <li>Cualquiera que crea que el trabajo puede ser también un lugar de crecimiento humano</li>\n      </ul>\n    </div>\n  </section>\n\n  <!-- CTA -->\n  <section class=\"cta\">\n    <div class=\"container\">\n      <h2>¿Te sumas?</h2>\n      <a href=\"/registro\" class=\"btn btn--primary btn--large\">\n        Quiero apuntarme a la próxima charla\n      </a>\n    </div>\n  </section>\n\n  <!-- Key section -->\n  <section class=\"key-section\">\n    <div class=\"container\">\n      <div class=\"key-section__card\">\n        <span class=\"key-section__icon\" aria-hidden=\"true\">🔑</span>\n        <h2>La llave de entrada es el libro</h2>\n        <p>\n          Para acceder a las charlas y al contenido exclusivo necesitas tener el\n          libro <strong>Liderazgo Afectivo</strong>. Si ya lo tienes, estás a un\n          paso. Si aún no lo tienes, te contamos cómo conseguirlo.\n        </p>\n        <a href=\"https://liderazgoafectivo.com\" class=\"btn btn--outline\">\n          Descubre el libro\n        </a>\n      </div>\n    </div>\n  </section>\n\n  <!-- Footer -->\n  <footer class=\"footer\">\n    <div class=\"container\">\n      <p>&copy; {new Date().getFullYear()} Liderazgo Afectivo — Mánu Fosela</p>\n    </div>\n  </footer>\n</Layout>\n\n<style>\n  /* ===== Utilities ===== */\n  .container {\n    max-width: var(--max-width);\n    margin: 0 auto;\n    padding: 0 var(--space-md);\n  }\n\n  .btn {\n    display: inline-block;\n    font-family: var(--font-body);\n    font-weight: 600;\n    border-radius: 8px;\n    cursor: pointer;\n    text-decoration: none;\n    transition: background-color 0.2s, transform 0.15s;\n    text-align: center;\n  }\n\n  .btn:hover {\n    text-decoration: none;\n    transform: translateY(-1px);\n  }\n\n  .btn--primary {\n    background-color: var(--color-gold);\n    color: var(--color-white);\n    padding: 0.875rem 2rem;\n    font-size: 1.05rem;\n  }\n\n  .btn--primary:hover {\n    background-color: var(--color-gold-dark);\n  }\n\n  .btn--large {\n    padding: 1rem 2.5rem;\n    font-size: 1.15rem;\n  }\n\n  .btn--outline {\n    border: 2px solid var(--color-gold);\n    color: var(--color-gold-dark);\n    padding: 0.75rem 1.75rem;\n    font-size: 1rem;\n    background: transparent;\n  }\n\n  .btn--outline:hover {\n    background-color: var(--color-gold);\n    color: var(--color-white);\n  }\n\n  /* ===== Hero ===== */\n  .hero {\n    background: linear-gradient(\n      165deg,\n      var(--color-bg-warm) 0%,\n      var(--color-bg-accent) 100%\n    );\n    padding: var(--space-2xl) 0;\n    text-align: center;\n  }\n\n  .hero__title {\n    font-size: clamp(1.75rem, 5vw, 3rem);\n    max-width: 800px;\n    margin: 0 auto var(--space-md);\n  }\n\n  .hero__subtitle {\n    font-size: clamp(1.05rem, 2.5vw, 1.3rem);\n    color: var(--color-text-light);\n    max-width: 650px;\n    margin: 0 auto var(--space-lg);\n  }\n\n  /* ===== Hook ===== */\n  .hook {\n    padding: var(--space-xl) 0;\n    text-align: center;\n  }\n\n  .hook__text {\n    font-size: 1.15rem;\n    max-width: 740px;\n    margin: 0 auto var(--space-sm);\n    color: var(--color-text-light);\n  }\n\n  .hook__highlight {\n    font-family: var(--font-heading);\n    font-size: 1.35rem;\n    font-weight: 600;\n    color: var(--color-gold-dark);\n    margin-top: var(--space-sm);\n  }\n\n  /* ===== What Is ===== */\n  .what-is {\n    background-color: var(--color-bg-warm);\n    padding: var(--space-xl) 0;\n    text-align: center;\n  }\n\n  .what-is h2 {\n    font-size: clamp(1.5rem, 3.5vw, 2rem);\n    margin-bottom: var(--space-md);\n  }\n\n  .what-is p {\n    font-size: 1.1rem;\n    max-width: 700px;\n    margin: 0 auto;\n    color: var(--color-text-light);\n  }\n\n  /* ===== Benefits ===== */\n  .benefits {\n    padding: var(--space-xl) 0;\n  }\n\n  .benefits h2 {\n    font-size: clamp(1.5rem, 3.5vw, 2rem);\n    text-align: center;\n    margin-bottom: var(--space-lg);\n  }\n\n  .benefits__list {\n    list-style: none;\n    display: grid;\n    gap: var(--space-md);\n    max-width: 750px;\n    margin: 0 auto;\n  }\n\n  .benefits__item {\n    display: flex;\n    align-items: flex-start;\n    gap: var(--space-sm);\n    background: var(--color-white);\n    padding: var(--space-md);\n    border-radius: 12px;\n    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);\n    font-size: 1.05rem;\n    line-height: 1.6;\n  }\n\n  .benefits__icon {\n    font-size: 1.4rem;\n    flex-shrink: 0;\n    margin-top: 2px;\n  }\n\n  /* ===== For Who ===== */\n  .for-who {\n    background-color: var(--color-bg-warm);\n    padding: var(--space-xl) 0;\n  }\n\n  .for-who h2 {\n    font-size: clamp(1.5rem, 3.5vw, 2rem);\n    text-align: center;\n    margin-bottom: var(--space-lg);\n  }\n\n  .for-who__list {\n    list-style: none;\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));\n    gap: var(--space-md);\n    max-width: 900px;\n    margin: 0 auto;\n  }\n\n  .for-who__list li {\n    background: var(--color-white);\n    padding: var(--space-md);\n    border-radius: 12px;\n    border-left: 4px solid var(--color-gold);\n    font-size: 1.02rem;\n    line-height: 1.6;\n    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);\n  }\n\n  /* ===== CTA ===== */\n  .cta {\n    padding: var(--space-2xl) 0;\n    text-align: center;\n  }\n\n  .cta h2 {\n    font-size: clamp(1.5rem, 3.5vw, 2.2rem);\n    margin-bottom: var(--space-lg);\n  }\n\n  /* ===== Key Section ===== */\n  .key-section {\n    background-color: var(--color-bg-accent);\n    padding: var(--space-xl) 0;\n  }\n\n  .key-section__card {\n    max-width: 650px;\n    margin: 0 auto;\n    text-align: center;\n    background: var(--color-white);\n    padding: var(--space-lg);\n    border-radius: 16px;\n    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);\n  }\n\n  .key-section__icon {\n    font-size: 2.5rem;\n    display: block;\n    margin-bottom: var(--space-sm);\n  }\n\n  .key-section__card h2 {\n    font-size: 1.5rem;\n    margin-bottom: var(--space-sm);\n  }\n\n  .key-section__card p {\n    color: var(--color-text-light);\n    margin-bottom: var(--space-md);\n    font-size: 1.05rem;\n  }\n\n  /* ===== Footer ===== */\n  .footer {\n    padding: var(--space-lg) 0;\n    text-align: center;\n    color: var(--color-text-light);\n    font-size: 0.9rem;\n    border-top: 1px solid var(--color-bg-accent);\n  }\n</style>\n","numLines":369,"startLine":1,"totalLines":369}}} (stream=stdout)
