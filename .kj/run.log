n    padding: var(--space-xl) 0;\n    text-align: center;\n  }\n\n  .hook__text {\n    font-size: 1.15rem;\n    max-width: 740px;\n    margin: 0 auto var(--space-sm);\n    color: var(--color-text-light);\n  }\n\n  .hook__highlight {\n    font-family: var(--font-heading);\n    font-size: 1.35rem;\n    font-weight: 600;\n    color: var(--color-gold-dark);\n    margin-top: var(--space-sm);\n  }\n\n  /* ===== What Is ===== */\n  .what-is {\n    background-color: var(--color-bg-warm);\n    padding: var(--space-xl) 0;\n    text-align: center;\n  }\n\n  .what-is h2 {\n    font-size: clamp(1.5rem, 3.5vw, 2rem);\n    margin-bottom: var(--space-md);\n  }\n\n  .what-is p {\n    font-size: 1.1rem;\n    max-width: 700px;\n    margin: 0 auto;\n    color: var(--color-text-light);\n  }\n\n  /* ===== Benefits ===== */\n  .benefits {\n    padding: var(--space-xl) 0;\n  }\n\n  .benefits h2 {\n    font-size: clamp(1.5rem, 3.5vw, 2rem);\n    text-align: center;\n    margin-bottom: var(--space-lg);\n  }\n\n  .benefits__list {\n    list-style: none;\n    display: grid;\n    gap: var(--space-md);\n    max-width: 750px;\n    margin: 0 auto;\n  }\n\n  .benefits__item {\n    display: flex;\n    align-items: flex-start;\n    gap: var(--space-sm);\n    background: var(--color-white);\n    padding: var(--space-md);\n    border-radius: 12px;\n    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);\n    font-size: 1.05rem;\n    line-height: 1.6;\n  }\n\n  .benefits__icon {\n    font-size: 1.4rem;\n    flex-shrink: 0;\n    margin-top: 2px;\n  }\n\n  /* ===== For Who ===== */\n  .for-who {\n    background-color: var(--color-bg-warm);\n    padding: var(--space-xl) 0;\n  }\n\n  .for-who h2 {\n    font-size: clamp(1.5rem, 3.5vw, 2rem);\n    text-align: center;\n    margin-bottom: var(--space-lg);\n  }\n\n  .for-who__list {\n    list-style: none;\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));\n    gap: var(--space-md);\n    max-width: 900px;\n    margin: 0 auto;\n  }\n\n  .