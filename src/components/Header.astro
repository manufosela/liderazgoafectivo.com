---
import type { Lang, PageKey, Translations } from '../i18n/translations';

interface Props {
	active?: PageKey;
	lang: Lang;
	translations: Translations;
	navigationPaths: Record<PageKey, string>;
	languageLinks: { es: string; en: string };
}

const {
	active = 'home',
	lang,
	translations,
	navigationPaths,
	languageLinks,
} = Astro.props;

const isEnglish = lang === 'en';
---

<header class="header">
	<nav class="nav-container">
		<div class="logo">
			<a href={navigationPaths.home} class="logo-link">
				<img src="/liderazgo_afectivo_logo.svg" alt={translations.common.siteName} class="logo-image">
				<span>{translations.common.siteName}</span>
			</a>
		</div>
		<button class="hamburger" id="menuToggle" aria-label={translations.common.hamburgerLabel} aria-expanded="false" aria-controls="mainNav">
			<span></span>
			<span></span>
			<span></span>
		</button>
		<div class="nav-links" id="mainNav">
			<a href={navigationPaths.home} class={`nav-link ${active === 'home' ? 'active' : ''}`}>{translations.nav.home}</a>
			<a href={navigationPaths.preview} class={`nav-link ${active === 'preview' ? 'active' : ''}`}>{translations.nav.preview}</a>
			<a href={navigationPaths.blog} class={`nav-link ${active === 'blog' ? 'active' : ''}`}>{translations.nav.blog}</a>
			<a href={navigationPaths.contact} class={`nav-link ${active === 'contact' ? 'active' : ''}`}>{translations.nav.contact}</a>
			<a href={translations.common.externalLinkUrl} class="nav-link external" target="_blank" rel="noopener">{translations.common.externalLinkLabel}</a>
			<label class="language-toggle" aria-label={translations.common.languageToggleLabel}>
				<span class={`toggle-label ${!isEnglish ? 'active' : ''}`}>ES</span>
				<input
					type="checkbox"
					role="switch"
					aria-checked={isEnglish}
					data-lang-toggle
					data-es-href={languageLinks.es}
					data-en-href={languageLinks.en}
					checked={isEnglish}
				/>
				<span class={`toggle-label ${isEnglish ? 'active' : ''}`}>EN</span>
				<span class="toggle-slider" aria-hidden="true"></span>
			</label>
		</div>
	</nav>
</header>

<script>
/**
 * Controla el menú hamburguesa en móvil.
 * @returns {void}
 */
document.addEventListener('DOMContentLoaded', function() {
	const menuToggle = document.getElementById('menuToggle');
	const mainNav = document.getElementById('mainNav');
	const langToggle = document.querySelector('[data-lang-toggle]');

	if (menuToggle && mainNav) {
		menuToggle.addEventListener('click', function() {
			const expanded = menuToggle.getAttribute('aria-expanded') === 'true';
			menuToggle.setAttribute('aria-expanded', (!expanded) + "");
			mainNav.classList.toggle('open');
		});
	}

	if (langToggle instanceof HTMLInputElement) {
		const currentLang = document.documentElement.lang === 'en' ? 'en' : 'es';
		langToggle.checked = currentLang === 'en';
		langToggle.setAttribute('aria-checked', currentLang === 'en' ? 'true' : 'false');

		langToggle.addEventListener('change', function() {
			const targetLang = this.checked ? 'en' : 'es';
			try {
				window.localStorage.setItem('preferredLang', targetLang);
			} catch {
				// Ignore storage errors (private mode, etc.)
			}
			const href = this.dataset[targetLang + 'Href'];
			if (href) {
				window.location.href = href;
			}
		});
	}
});
</script>

<style>
	.header {
		background: rgba(0, 0, 0, 0.8);
		padding: 1rem 0;
		position: sticky;
		top: 0;
		z-index: 100;
		backdrop-filter: blur(10px);
	}

	.nav-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 1.5rem;
		align-items: center;
		position: relative;
	}

	.logo {
		display: flex;
		align-items: center;
	}

	.logo-link {
		display: flex;
		align-items: center;
		gap: 1rem;
		text-decoration: none;
	}

	.logo-image {
		height: 40px;
		width: auto;
		filter: invert(80%) sepia(32%) saturate(1011%) hue-rotate(359deg) brightness(103%) contrast(94%);
	}

	.logo-link span {
		color: white;
		font-size: 1.5rem;
		font-weight: bold;
		transition: color 0.3s ease;
	}

	.logo-link:hover span {
		color: #f3d229;
	}

	.nav-links {
		display: flex;
		gap: 2rem;
		align-items: center;
		transition: max-height 0.3s ease, opacity 0.3s ease;
	}

	.nav-link {
		color: white;
		text-decoration: none;
		transition: color 0.3s ease;
		position: relative;
	}

	.nav-link:hover {
		color: #f3d229;
	}

	.nav-link.active {
		color: #f3d229;
	}

	.nav-link.active::after {
		content: '';
		position: absolute;
		bottom: -5px;
		left: 0;
		width: 100%;
		height: 2px;
		background-color: #f3d229;
	}

	.nav-link.external {
		background: #f3d229;
		color: #000;
		padding: 0.5rem 1rem;
		border-radius: 4px;
		font-weight: bold;
	}

	.nav-link.external:hover {
		background: #e6c824;
		color: #000;
	}

	.hamburger {
		display: none;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		width: 40px;
		height: 40px;
		background: none;
		border: none;
		cursor: pointer;
		gap: 5px;
		z-index: 200;
	}

	.hamburger span {
		display: block;
		width: 28px;
		height: 3px;
		background: #fff;
		border-radius: 2px;
		transition: all 0.3s;
	}

	.language-toggle {
		position: relative;
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.25rem 0.75rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.1);
		cursor: pointer;
		user-select: none;
		overflow: hidden;
	}

	.language-toggle input {
		position: absolute;
		opacity: 0;
		pointer-events: none;
	}

	.toggle-label {
		font-size: 0.85rem;
		color: rgba(255, 255, 255, 0.7);
		font-weight: 600;
		transition: color 0.2s ease;
		position: relative;
		z-index: 1;
	}

	.toggle-label.active {
		color: #fff;
	}

	.toggle-slider {
		position: absolute;
		top: 0.25rem;
		bottom: 0.25rem;
		left: 0.35rem;
		width: calc(50% - 0.35rem);
		background: #f3d229;
		border-radius: 999px;
		transform: translateX(0);
		transition: transform 0.25s ease;
		z-index: 0;
	}

	.language-toggle input:checked ~ .toggle-slider {
		transform: translateX(100%);
	}

	@media (max-width: 900px) {
		.nav-container {
			padding: 1rem;
			grid-template-columns: auto auto;
			grid-template-rows: auto auto;
		}
		.hamburger {
			display: flex;
			grid-row: 1;
			grid-column: 2;
			justify-self: end;
		}
		.nav-links {
			position: absolute;
			top: 100%;
			right: 0;
			background: rgba(0,0,0,0.97);
			flex-direction: column;
			align-items: flex-end;
			gap: 0;
			width: 220px;
			max-height: 0;
			overflow: hidden;
			opacity: 0;
			border-radius: 0 0 0 12px;
			box-shadow: 0 8px 32px rgba(0,0,0,0.18);
			transition: max-height 0.3s, opacity 0.3s;
			z-index: 150;
		}
		.nav-links.open {
			max-height: 500px;
			opacity: 1;
			padding: 1rem 0;
		}
		.nav-link {
			width: 100%;
			text-align: right;
			padding: 0.8rem 1.5rem;
			font-size: 1.1rem;
		}
		.nav-link.external {
			margin-top: 0.5rem;
		}
		.language-toggle {
			margin: 0.5rem 1.5rem 0;
			align-self: center;
		}
		.logo-image {
			height: 30px;
		}
		.logo-link span {
			font-size: 1.2rem;
		}
		.site-footer {
			padding:0;
		}
	}
</style> 
