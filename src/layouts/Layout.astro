---
import type { Lang, Translations } from '../i18n/translations';

interface Props {
	title: string;
	description?: string;
	canonicalUrl?: string;
	lang: Lang;
	translations: Translations;
	alternateUrls?: Partial<Record<Lang | 'x-default', string>>;
}

const {
	title,
	description = 'Liderazgo Afectivo - Un libro sobre liderazgo emocional y gestión de equipos',
	canonicalUrl = 'https://liderazgoafectivo.com',
	lang,
	translations,
	alternateUrls = {},
} = Astro.props;

const siteName = translations.common.siteName;
const bookDescription = translations.common.bookDescription;
const bookEdition = translations.common.bookEdition;
const ogLocale = translations.common.ogLocale;
const bookCoverImage = translations.common.bookCoverImage;

const siteBaseUrl = 'https://liderazgoafectivo.com';
const coverImageAbsolute = bookCoverImage.startsWith('http') ? bookCoverImage : `${siteBaseUrl}${bookCoverImage}`;

const bookSchema = {
	'@context': 'https://schema.org',
	'@type': 'Book',
	name: siteName,
	author: {
		'@type': 'Person',
		name: 'Manuel Fosela',
		url: 'https://manufosela.es',
		sameAs: ['https://twitter.com/manufosela', 'https://linkedin.com/in/manufosela'],
	},
	publisher: {
		'@type': 'Organization',
		name: 'Savvily Editorial',
		url: 'https://savvily.es',
	},
	datePublished: '2025-04-03',
	description: bookDescription,
	image: coverImageAbsolute,
	offers: {
		'@type': 'Offer',
		url: 'https://savvily.es/libros/liderazgo-afectivo/',
		priceCurrency: 'EUR',
		availability: 'https://schema.org/InStock',
	},
	workExample: {
		'@type': 'Book',
		bookEdition,
		bookFormat: 'https://schema.org/Paperback',
		numberOfPages: '250',
	},
};

const websiteSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: siteName,
	url: 'https://liderazgoafectivo.com',
};
---

<!DOCTYPE html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		{lang === 'es' && alternateUrls.en && (
			<script is:inline define:vars={{ enUrl: alternateUrls.en }}>
				(function() {
					try {
						var stored = localStorage.getItem('preferredLang');
						if (stored) return;
						var browserLang = (navigator.languages && navigator.languages[0]) || navigator.language || '';
						if (!browserLang.toLowerCase().startsWith('es')) {
							localStorage.setItem('preferredLang', 'en');
							location.replace(enUrl);
						}
					} catch(e) {}
				})();
			</script>
		)}
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />

		<!-- Alternate language URLs -->
		{Object.entries({ ...alternateUrls }).map(([hrefLang, url]) => (
			<link rel="alternate" hreflang={hrefLang} href={url} />
		))}

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
	<meta property="og:image" content={coverImageAbsolute} />
		<meta property="og:site_name" content={siteName} />
		<meta property="og:locale" content={ogLocale} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalUrl} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
	<meta property="twitter:image" content={coverImageAbsolute} />
		<meta property="twitter:creator" content="@manufosela" />

		<!-- Schema.org para el libro -->
		<script type="application/ld+json">{JSON.stringify(bookSchema)}</script>

		<!-- Schema.org para el sitio web -->
		<script type="application/ld+json">{JSON.stringify(websiteSchema)}</script>
	</head>
	<body>
		<slot />
		<style is:global>
			:root {
				--font-heading: 'Playfair Display', Georgia, serif;
				--font-body: system-ui, -apple-system, sans-serif;
				--color-bg: #13151A;
				--color-gold: #f3d229;
				--color-gold-hover: #e6c824;
				--header-height: 70px;
				--footer-height: 60px;
			}
			html {
				font-family: var(--font-body);
				background: var(--color-bg);
				color: white;
			}
			body {
				margin: 0;
				min-height: 100vh;
				display: flex;
				flex-direction: column;
				line-height: 1.6;
			}
			main {
				padding-bottom: calc(var(--footer-height) + 2rem);
			}
			h1, h2, h3 {
				font-family: var(--font-heading);
			}
			:focus-visible {
				outline: 2px solid var(--color-gold);
				outline-offset: 2px;
			}
		</style>
	</body>
</html>
