---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getPageSetup, PATHS } from '../i18n/translations';
import '../styles/pages/contact.css';

const { lang, translations, title, description, canonicalUrl, alternateUrls, languageLinks, navigationPaths } = getPageSetup('es', 'contact');
---

<Layout {title} {description} {canonicalUrl} lang={lang} {translations} {alternateUrls}>
	<Header
		active="contact"
		lang={lang}
		{translations}
		{navigationPaths}
		{languageLinks}
	/>
	
	<main class="contact-content">
		<h1>{translations.contact.heading}</h1>
		<p class="contact-description">{translations.contact.description}</p>
		
		<div class="contact-grid">
			<section class="contact-form-section">
				<form id="contactForm" class="contact-form" action="https://formspree.io/f/mrbqjrkv" method="POST">
					<div class="form-group">
						<span class="input-icon">
							<!-- Icono usuario -->
							<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="8" r="4" stroke="#bdbdbd" stroke-width="2"/><path d="M4 20c0-2.21 3.582-4 8-4s8 1.79 8 4" stroke="#bdbdbd" stroke-width="2"/></svg>
						</span>
						<label for="name">{translations.contact.fields.name}</label>
						<input type="text" id="name" name="name" required>
					</div>
					
					<div class="form-group">
						<span class="input-icon">
							<!-- Icono email -->
							<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="5" width="18" height="14" rx="2" stroke="#bdbdbd" stroke-width="2"/><path d="M3 7l9 6 9-6" stroke="#bdbdbd" stroke-width="2"/></svg>
						</span>
						<label for="email">{translations.contact.fields.email}</label>
						<input type="email" id="email" name="email" required>
					</div>
					
					<div class="form-group">
						<span class="input-icon">
							<!-- Icono asunto -->
							<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="4" y="4" width="16" height="16" rx="4" stroke="#bdbdbd" stroke-width="2"/><path d="M8 12h8" stroke="#bdbdbd" stroke-width="2" stroke-linecap="round"/></svg>
						</span>
						<label for="subject">{translations.contact.fields.subject}</label>
						<input type="text" id="subject" name="subject" required>
					</div>
					
					<div class="form-group">
						<span class="input-icon">
							<!-- Icono mensaje -->
							<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="5" width="18" height="14" rx="2" stroke="#bdbdbd" stroke-width="2"/><path d="M3 7l9 6 9-6" stroke="#bdbdbd" stroke-width="2"/></svg>
						</span>
						<label for="message">{translations.contact.fields.message}</label>
						<textarea id="message" name="message" rows="5" required></textarea>
					</div>
					
					<button type="submit" class="submit-button">{translations.contact.submit}</button>
				</form>
			</section>
			
			<section class="contact-info-box">
				<h2>{translations.contact.otherHeading}</h2>
				<div class="social-links">
					<a href="https://twitter.com/manufosela" target="_blank" class="social-link">
						<svg class="social-icon" viewBox="0 0 24 24">
							<path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
						</svg>
						{translations.contact.links.twitter}
					</a>
					
					<a href="https://linkedin.com/in/manufosela" target="_blank" class="social-link">
						<svg class="social-icon" viewBox="0 0 24 24">
							<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
						</svg>
						{translations.contact.links.linkedin}
					</a>
					
					<a href="https://manufosela.es" target="_blank" class="social-link">
						<svg class="social-icon" viewBox="0 0 24 24">
							<path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm0 22c-5.514 0-10-4.486-10-10S6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z"/>
							<path d="M12 4c-4.411 0-8 3.589-8 8s3.589 8 8 8 8-3.589 8-8-3.589-8-8-8zm0 14c-3.309 0-6-2.691-6-6s2.691-6 6-6 6 2.691 6 6-2.691 6-6 6z"/>
						</svg>
						{translations.contact.links.personal}
					</a>
				</div>
			</section>
		</div>
	</main>

	<Footer lang={lang} translations={translations} />
</Layout>
