---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getTranslations, getAlternateLang, getLanguagePaths, PATHS } from '../i18n/translations';

const lang = 'es';
const pageKey = 'preview';
const translations = getTranslations(lang);
const alternateLang = getAlternateLang(lang);
const alternateTranslations = getTranslations(alternateLang);
const languageLinks = getLanguagePaths(pageKey);

const title = translations.preview.meta.title;
const description = translations.preview.meta.description;
const canonicalUrl = translations.preview.meta.canonical;

const alternateUrls = {
	es: translations.preview.meta.canonical,
	en: alternateTranslations.preview.meta.canonical,
	'x-default': translations.preview.meta.canonical,
};
---

<Layout
	{title}
	{description}
	{canonicalUrl}
	lang={lang}
	siteName={translations.common.siteName}
	bookDescription={translations.common.bookDescription}
	bookEdition={translations.common.bookEdition}
	ogLocale={translations.common.ogLocale}
	bookCoverImage={translations.common.bookCoverImage}
	alternateUrls={alternateUrls}
>
	<Header
		active={pageKey}
		lang={lang}
		translations={translations}
		navigationPaths={PATHS[lang]}
		languageLinks={languageLinks}
	/>
	
	<main class="preview-content">
		<article class="book-preview">
			<h1>{translations.preview.heading}</h1>
			<div class="pdf-viewer-container">
				<iframe 
					src="https://savvily.es/libros/liderazgo-afectivo/muestra-liderazgo-afectivo.pdf"
					width="100%"
					height="700"
					style="border: none; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.08);"
					title={translations.preview.iframeTitle}
					allowfullscreen
				></iframe>
			</div>
			<div class="cta-container">
				<a href={translations.home.savvilyUrl} class="buy-button savvily" target="_blank" rel="noopener">{translations.home.announcementLinkLabel}</a>
				<a href={translations.home.amazonPaperUrl} class="buy-button amazon" target="_blank" rel="noopener">{translations.home.amazonPaperLabel}</a>
			</div>
		</article>
	</main>

	<Footer lang={lang} translations={translations} />
</Layout>

<style>
	h1 {
		margin:0.5rem 0;
		color: #000;
	}
	.preview-content {
		max-width: 100vw;
		margin: 0;
		padding: 0;
	}

	.book-preview {
		background: white;
		padding: 0;
		border-radius: 0;
		box-shadow: none;
		display: flex;
		flex-direction: column;
		align-items: center;
		max-height: 85dvh;
	}

	.pdf-viewer-container {
		margin: 0;
		border-radius: 0;
		overflow: hidden;
		box-shadow: none;
		width: 100vw;
		max-width: 900px;
		display: flex;
		justify-content: center;
	}

	.pdf-viewer-container iframe {
		width: 100%;
		max-width: 900px;
		height: 90vh;
		min-height: 600px;
		display: block;
		margin: 0 auto;
		border-radius: 0;
	}

	.cta-container {
		text-align: center;
		margin: 2rem auto 0 auto;
		width: 100%;
		max-width: 900px;
		display: flex;
		justify-content: center;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.buy-button {
		display: inline-block;
		padding: 1rem 2rem;
		text-decoration: none;
		border-radius: 4px;
		font-weight: bold;
		transition: all 0.3s ease;
	}

	.buy-button.savvily {
		background-color: #f3d229;
		color: #000;
	}

	.buy-button.savvily:hover {
		background-color: #fff;
		transform: translateY(-2px);
	}

	.buy-button.amazon {
		background-color: #ff9900;
		color: #000;
	}

	.buy-button.amazon:hover {
		background-color: #ffad33;
		transform: translateY(-2px);
	}

	@media (max-width: 950px) {
		.pdf-viewer-container,
		.cta-container {
			max-width: 100vw;
		}
		.pdf-viewer-container iframe {
			max-width: 100vw;
		}

		h1 {
			font-size: 1.2rem;
			margin:0 auto;
			text-align: center;
			width: 100%;
		}
	}

	@media (max-width: 768px) {
		.pdf-viewer-container iframe {
			height: 60vh;
			min-height: 300px;
		}

		h1 {
			font-size: 1.2rem;
			margin:0 auto;
			text-align: center;
			width: 100%;
		}
	}
</style> 
