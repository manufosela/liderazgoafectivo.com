---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getPageSetup, PATHS } from '../../i18n/translations';
import '../../styles/pages/preview.css';

const { lang, translations, title, description, canonicalUrl, alternateUrls, languageLinks, navigationPaths } = getPageSetup('en', 'preview');
---

<Layout {title} {description} {canonicalUrl} lang={lang} {translations} {alternateUrls}>
	<Header
		active="preview"
		lang={lang}
		{translations}
		{navigationPaths}
		{languageLinks}
	/>

	<main class="preview-content">
		<article class="book-preview">
			<h1>{translations.preview.heading}</h1>
			<div class="pdf-viewer-container">
				<iframe
					src="/affective-leadership-sample.pdf"
					width="100%"
					height="700"
					style="border: none; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.08);"
					title={translations.preview.iframeTitle}
					allowfullscreen
				></iframe>
			</div>
			<div class="cta-container">
				<a href={translations.home.amazonPaperUrl} class="buy-button amazon" target="_blank" rel="noopener">{translations.home.amazonPaperLabel}</a>
				<a href={translations.home.amazonKindleUrl} class="buy-button kindle" target="_blank" rel="noopener">{translations.home.amazonKindleLabel}</a>
			</div>
		</article>
	</main>

	<Footer lang={lang} translations={translations} />
</Layout>
