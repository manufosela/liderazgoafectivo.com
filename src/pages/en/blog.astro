---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getTranslations, getAlternateLang, getLanguagePaths, PATHS } from '../../i18n/translations';

const lang = 'en';
const pageKey = 'blog';
const translations = getTranslations(lang);
const alternateLang = getAlternateLang(lang);
const alternateTranslations = getTranslations(alternateLang);
const languageLinks = getLanguagePaths(pageKey);

const title = translations.blog.meta.title;
const description = translations.blog.meta.description;
const canonicalUrl = translations.blog.meta.canonical;

const alternateUrls = {
	en: translations.blog.meta.canonical,
	es: alternateTranslations.blog.meta.canonical,
	'x-default': alternateTranslations.blog.meta.canonical,
};
---

<Layout
	{title}
	{description}
	{canonicalUrl}
	lang={lang}
	siteName={translations.common.siteName}
	bookDescription={translations.common.bookDescription}
	bookEdition={translations.common.bookEdition}
	ogLocale={translations.common.ogLocale}
	bookCoverImage={translations.common.bookCoverImage}
	alternateUrls={alternateUrls}
>
	<Header
		active={pageKey}
		lang={lang}
		translations={translations}
		navigationPaths={PATHS[lang]}
		languageLinks={languageLinks}
	/>

	<main class="blog-content">
		<h1>{translations.blog.heading}</h1>
		<p class="blog-description">{translations.blog.description}</p>

		<div class="blog-redirect">
			<a href="https://manufosela.substack.com" class="substack-link" target="_blank" rel="noopener noreferrer">
				{translations.blog.ctaLabel}
			</a>
		</div>

		<section class="blog-info">
			<h2>{translations.blog.sectionHeading}</h2>
			<p>{translations.blog.sectionIntro}</p>
			<ul>
				{translations.blog.bullets.map((item) => (
					<li>{item}</li>
				))}
			</ul>
		</section>
	</main>

	<Footer lang={lang} translations={translations} />
</Layout>

<style>
	.blog-content {
		max-width: 1200px;
		margin: 0 auto;
		padding: 2rem;
		text-align: center;
	}

	.blog-description {
		text-align: center;
		margin-bottom: 3rem;
		font-size: 1.2rem;
		color: #666;
	}

	.blog-redirect {
		margin: 4rem 0;
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
	}

	.substack-link {
		display: inline-block;
		padding: 1rem 2rem;
		background-color: #f3d229;
		color: #000;
		text-decoration: none;
		border-radius: 4px;
		font-weight: bold;
		font-size: 1.1rem;
		transition: all 0.3s ease;
	}

	.substack-link:hover {
		background-color: #e6c824;
		transform: translateY(-2px);
	}

	.blog-info {
		text-align: left;
		max-width: 800px;
		margin: 2rem auto;
		padding: 2rem;
		background: rgba(243, 210, 41, 0.1);
		border-radius: 8px;
		color: #f3f3f3;
	}

	.blog-info h2 {
		color: #f3f3f3;
		margin-bottom: 1rem;
	}

	.blog-info p,
	.blog-info li {
		color: #f3f3f3;
	}

	.blog-info ul {
		list-style-type: none;
		padding: 0;
	}

	.blog-info li {
		margin: 1rem 0;
		padding-left: 1.5rem;
		position: relative;
	}

	.blog-info li:before {
		content: "•";
		color: #f3d229;
		position: absolute;
		left: 0;
	}

	@media (max-width: 768px) {
		.blog-content {
			padding: 1rem;
		}

		.blog-info {
			padding: 1rem;
		}
	}
</style>
