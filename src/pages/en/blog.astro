---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getPageSetup, PATHS } from '../../i18n/translations';
import '../../styles/pages/blog.css';

const { lang, translations, title, description, canonicalUrl, alternateUrls, languageLinks, navigationPaths } = getPageSetup('en', 'blog');
---

<Layout {title} {description} {canonicalUrl} lang={lang} {translations} {alternateUrls}>
	<Header
		active="blog"
		lang={lang}
		{translations}
		{navigationPaths}
		{languageLinks}
	/>

	<main class="blog-content">
		<h1>{translations.blog.heading}</h1>
		<p class="blog-description">{translations.blog.description}</p>

		<div class="blog-redirect">
			<p class="language-notice">{translations.blog.languageNotice}</p>
			<a href="https://manufosela.substack.com" class="substack-link" target="_blank" rel="noopener noreferrer">
				{translations.blog.ctaLabel}
			</a>
		</div>

		<section class="blog-info">
			<h2>{translations.blog.sectionHeading}</h2>
			<p>{translations.blog.sectionIntro}</p>
			<ul>
				{translations.blog.bullets.map((item) => (
					<li>{item}</li>
				))}
			</ul>
		</section>
	</main>

	<Footer lang={lang} translations={translations} />
</Layout>
