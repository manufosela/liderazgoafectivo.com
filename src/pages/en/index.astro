---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getPageSetup, PATHS } from '../../i18n/translations';
import '../../styles/pages/home.css';

const { lang, translations, title, description, canonicalUrl, alternateUrls, languageLinks, navigationPaths } = getPageSetup('en', 'home');
---

<Layout {title} {description} {canonicalUrl} lang={lang} {translations} {alternateUrls}>
	<Header
		active="home"
		lang={lang}
		{translations}
		{navigationPaths}
		{languageLinks}
	/>

	<main class="main-content">
		<div class="video-container">
			<video autoplay loop muted playsinline class="background-video" poster={translations.common.bookCoverImage} preload="none">
				<source src="/liderazgoafectivo_videoinicial.mp4" type="video/mp4">
			</video>
			<div class="video-overlay"></div>
		</div>

		<div class="content-wrapper">
			<img src={translations.common.bookCoverImage} alt={translations.home.videoAlt} class="book-cover" width="400" height="600" loading="lazy">
			<div class="announcement">
				<p class="publisher">{translations.home.publisher}</p>
				<div class="buy-links">
					<a href={translations.home.amazonPaperUrl} target="_blank" rel="noopener" class="buy-button amazon">{translations.home.amazonPaperLabel}</a>
					<a href={translations.home.amazonKindleUrl} target="_blank" rel="noopener" class="buy-button kindle">{translations.home.amazonKindleLabel}</a>
				</div>
				<div class="book-links">
					<a href={PATHS[lang].preview} class="preview-button">{translations.home.previewButton}</a>
				</div>
			</div>
		</div>
	</main>

	<Footer lang={lang} translations={translations} />
</Layout>
