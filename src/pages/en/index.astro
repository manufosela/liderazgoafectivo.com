---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getTranslations, getAlternateLang, getLanguagePaths, PATHS } from '../../i18n/translations';

const lang = 'en';
const pageKey = 'home';
const translations = getTranslations(lang);
const alternateLang = getAlternateLang(lang);
const alternateTranslations = getTranslations(alternateLang);
const languageLinks = getLanguagePaths(pageKey);

const title = translations.home.meta.title;
const description = translations.home.meta.description;
const canonicalUrl = translations.home.meta.canonical;

const alternateUrls = {
	en: translations.home.meta.canonical,
	es: alternateTranslations.home.meta.canonical,
	'x-default': alternateTranslations.home.meta.canonical,
};
---

<Layout
	{title}
	{description}
	{canonicalUrl}
	lang={lang}
	siteName={translations.common.siteName}
	bookDescription={translations.common.bookDescription}
	bookEdition={translations.common.bookEdition}
	ogLocale={translations.common.ogLocale}
	bookCoverImage={translations.common.bookCoverImage}
	alternateUrls={alternateUrls}
>
	<Header
		active={pageKey}
		lang={lang}
		translations={translations}
		navigationPaths={PATHS[lang]}
		languageLinks={languageLinks}
	/>

	<main class="main-content">
		<div class="video-container">
			<video autoplay loop muted playsinline class="background-video">
				<source src="/liderazgoafectivo_videoinicial.mp4" type="video/mp4">
			</video>
			<div class="video-overlay"></div>
		</div>

		<div class="content-wrapper">
			<img src={translations.common.bookCoverImage} alt={translations.home.videoAlt} class="book-cover">
			<div class="announcement">
				<p class="publisher">{translations.home.publisher} <a href="https://savvily.es/libros/liderazgo-afectivo/" target="_blank">{translations.home.announcementLinkLabel}</a></p>
				<div class="book-links">
					<a href={PATHS[lang].preview} class="preview-button">{translations.home.previewButton}</a>
				</div>
			</div>
		</div>
	</main>

	<Footer lang={lang} translations={translations} />
</Layout>

<style>
	.main-content {
		position: relative;
		width: 100%;
		height: calc(100vh - 60px);
		overflow: hidden;
		margin-bottom: 60px;
	}

	.video-container {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 1;
	}

	.video-overlay {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: rgba(0, 0, 0, 0.6);
		z-index: 2;
	}

	.background-video {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		min-width: 100%;
		min-height: 100%;
		width: auto;
		height: auto;
		object-fit: cover;
	}

	.content-wrapper {
		position: relative;
		z-index: 3;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 2rem;
		height: 90%;
		padding: 0;
	}

	.book-cover {
		max-height: 60vh;
		width: auto;
		border-radius: 8px;
		box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3);
	}

	.announcement {
		background: rgba(0, 0, 0, 0.7);
		padding: 1.5rem;
		border-radius: 8px;
	}

	.publisher {
		font-size: 1.5rem;
		color: white;
		margin: 0;
		text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
		text-align: center;
	}

	.publisher a {
		color: #f3d229;
		text-decoration: none;
		transition: color 0.3s ease;
	}

	.publisher a:hover {
		color: #fff;
		text-decoration: underline;
	}

	.preview-button {
		display: inline-block;
		margin-top: 1rem;
		padding: 0.8rem 1.5rem;
		background-color: #f3d229;
		color: #000;
		text-decoration: none;
		border-radius: 4px;
		font-weight: bold;
		transition: all 0.3s ease;
	}

	.preview-button:hover {
		background-color: #fff;
		transform: translateY(-2px);
	}

	.book-links {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
		margin-top: 1rem;
	}

	@media (max-width: 768px) {
		.book-cover {
			max-height: 40vh;
		}

		.publisher {
			font-size: 1.2rem;
		}

		.announcement {
			padding: 1rem;
			margin: 0 1rem;
		}
	}
</style>
